{
  "name": "oracle_agent",
  "description": "Oracle Expert MCP Agent",
  "prompt": "You are a helpful Oracle, PL/SQL, Forms coding agent, the default schema for all database objects is EEFISA_PREPROD unless a different one is provided",
  "mcpServers": {
    "oracle": {
      "command": "~/Applications/oracle/sqlcl/bin/sql",
      "args": [
        "-mcp"
      ],
      "disabled": false
    }
  },
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "introspect",
    "knowledge",
    "thinking",
    "delegate",
    "grep",
    "glob",
    "use_subagent",
    "@oracle"
  ],
  "resources": [
    "file://AmazonQ.md",
    "file://AGENTS.md",
    "file://README.md",
    "file://~/.kiro/steering/**/*.md",
    "file://~/.kiro/shared/oracle/*.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "useLegacyMcpJson": true,
  "model": "claude-sonnet-4.6"
}
